<?xml version="1.0" encoding="utf-8" ?>
<Patch>
  <Operation Class="PatchOperationReplace">
    <xpath>Defs/HediffDef[defName="BloodLoss"]/lethalSeverity</xpath>
    <value>
      <lethalSeverity>0.55</lethalSeverity>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/HediffDef[defName="BloodLoss"]/stages</xpath>
    <value>
      <stages>
        <li>
          <label>Minor blood loss</label>
          <becomeVisible>false</becomeVisible>
        </li>
        <li>
          <minSeverity>0.05</minSeverity>
          <label>Class I hemorrhagic shock - compensated</label>
          <becomeVisible>false</becomeVisible>
        </li>
        <li>
          <minSeverity>0.15</minSeverity>
          <label>Class II hemorrhagic shock</label>
          <capMods>
            <li><capacity>Consciousness</capacity><offset>-0.10</offset></li>
            <li><capacity>Moving</capacity><offset>-0.10</offset></li>
          </capMods>
        </li>
        <li>
          <minSeverity>0.25</minSeverity>
          <label>Class III hemorrhagic shock</label>
          <lifeThreatening>true</lifeThreatening>
          <capMods>
            <li><capacity>Consciousness</capacity><setMax>0.30</setMax></li>
            <li><capacity>Moving</capacity><offset>-0.30</offset></li>
            <li><capacity>BloodPumping</capacity><offset>-0.15</offset></li>
          </capMods>
          <hediffGivers>
            <li Class="HediffGiver_Random">
              <hediff>EE_MyocardialInfarction</hediff>
              <mtbDays>0.05</mtbDays> 
              <partsToAffect>
                <li>Heart</li>
              </partsToAffect>
            </li>
          </hediffGivers>
        </li>
        <li>
          <minSeverity>0.40</minSeverity>
          <label>Class IV hemorrhagic shock - terminal</label>
          <lifeThreatening>true</lifeThreatening>
          <capMods>
            <li><capacity>Consciousness</capacity><setMax>0.10</setMax></li>
            <li><capacity>BloodPumping</capacity><setMax>0.20</setMax></li>
            <li><capacity>Breathing</capacity><setMax>0.20</setMax></li>
          </capMods>
          <hediffGivers>
            <li Class="HediffGiver_Random">
              <hediff>EE_MyocardialInfarction</hediff>
              <mtbDays>0.01</mtbDays> 
              <partsToAffect>
                <li>Heart</li>
              </partsToAffect>
            </li>
          </hediffGivers>
        </li>
      </stages>
    </value>
  </Operation>
  
<!-- 枪伤流血速度 -->
  <Operation Class="PatchOperationConditional">
    <xpath>Defs/HediffDef[defName="Gunshot"]/injuryProps/bleedRate</xpath>
    <match Class="PatchOperationReplace">
      <xpath>Defs/HediffDef[defName="Gunshot"]/injuryProps/bleedRate</xpath>
      <value>
        <bleedRate>0.08</bleedRate> </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>Defs/HediffDef[defName="Gunshot"]/injuryProps</xpath>
      <value>
        <bleedRate>0.08</bleedRate>
      </value>
    </nomatch>
  </Operation>

 <!-- 切割伤流血速度 -->
  <Operation Class="PatchOperationConditional">
    <xpath>Defs/HediffDef[defName="Cut"]/injuryProps/bleedRate</xpath>
    <match Class="PatchOperationReplace">
      <xpath>Defs/HediffDef[defName="Cut"]/injuryProps/bleedRate</xpath>
      <value>
