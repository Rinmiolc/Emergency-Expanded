<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef ParentName="InjuryBase">
    <defName>TissueHypoxia</defName>
    <label>Tissue hypoxia</label>
    <labelNoun>hypoxic tissue</labelNoun>
    <description>Local tissue damage from severe hypoxia and metabolic acidosis. Similar to frostbite, it continuously degrades health; without restored perfusion, the part will necrotize and slough off.</description>
    <hediffClass>EmergencyExpanded.Hediff_TissueHypoxia</hediffClass>
    <initialSeverity>3.0</initialSeverity> 
    <tendable>false</tendable>
    <displayWound>false</displayWound>
    <injuryProps>
      <painPerSeverity>0.015</painPerSeverity>
      <averagePainPerSeverityPermanent>0.005</averagePainPerSeverityPermanent>
      <canMerge>true</canMerge> 
      <destroyedLabel>tissue necrosis</destroyedLabel>
      <destroyedOutLabel>tissue necrosis</destroyedOutLabel>
    </injuryProps>
  </HediffDef>

  <HediffDef>
    <defName>MetabolicAcidosis</defName>
    <label>Metabolic acidosis</label>
    <description>Systemic pH breakdown caused by severe tissue hypoperfusion. Once established, acidosis progressively damages the body, ultimately inducing irreversible multiple organ dysfunction syndrome (MODS) and death.</description>
    <hediffClass>EmergencyExpanded.Hediff_MetabolicAcidosis</hediffClass>
    <defaultLabelColor>(0.8, 0.8, 0.3)</defaultLabelColor>
    <maxSeverity>1.0</maxSeverity> 
    <initialSeverity>0.1</initialSeverity>
    <makesSickThought>true</makesSickThought>
    <tendable>false</tendable>
    <comps>
      <li Class="EmergencyExpanded.HediffCompProperties_Acidosis">
        <severityIncreasePerDay>2.0</severityIncreasePerDay>
        <severityDecreasePerDay>1.2</severityDecreasePerDay>
        <bloodPumpingThreshold>0.50</bloodPumpingThreshold>
        <breathingThreshold>0.50</breathingThreshold>
      </li>
    </comps>
    <stages>
      <li>
        <label>Mild</label>
        <capMods>
          <li><capacity>Breathing</capacity><offset>-0.2</offset></li>
          <li><capacity>BloodPumping</capacity><offset>-0.2</offset></li> 
        </capMods>
      </li>
      <li>
        <minSeverity>0.2</minSeverity>
        <label>Moderate</label>
        <painOffset>0.1</painOffset>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>-0.2</offset></li>
          <li><capacity>BloodPumping</capacity><offset>-0.2</offset></li> 
        </capMods>
      </li>
      <li>
        <minSeverity>0.5</minSeverity>
        <label>Severe</label>
        <lifeThreatening>true</lifeThreatening>
        <painOffset>0.25</painOffset>
        <capMods>
          <li><capacity>Consciousness</capacity><setMax>0.5</setMax></li>
          <li><capacity>BloodPumping</capacity><setMax>0.5</setMax></li> 
        </capMods>
        <hediffGivers>
          <li Class="HediffGiver_Random">
            <hediff>EE_MyocardialInfarction</hediff>
            <mtbDays>0.03</mtbDays> 
            <partsToAffect>
              <li>Heart</li>
            </partsToAffect>
          </li>
        </hediffGivers>
      </li>
      <li>
        <minSeverity>0.95</minSeverity>
        <label>Extreme - Near collapse</label> 
        <lifeThreatening>true</lifeThreatening>
        <painOffset>0.40</painOffset>
        <capMods>
          <li><capacity>Consciousness</capacity><setMax>0.3</setMax></li>
          <li><capacity>BloodPumping</capacity><setMax>0.3</setMax></li>
        </capMods>
        <hediffGivers>
          <li Class="HediffGiver_Random">
            <hediff>EE_MyocardialInfarction</hediff>
            <mtbDays>0.1</mtbDays> 
            <partsToAffect>
              <li>Heart</li>
            </partsToAffect>
          </li>
        </hediffGivers>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>EE_MyocardialInfarction</defName>
    <label>Myocardial infarction</label>
    <description>Acute coronary artery occlusion leading to myocardial necrosis. Causes catastrophic pumping and circulatory failure. If not treated with defibrillation/rescue, it triggers systemic hypoxia and death.</description>
    <hediffClass>EmergencyExpanded.Hediff_MyocardialInfarction</hediffClass>
    <defaultLabelColor>(0.9, 0.2, 0.2)</defaultLabelColor>
    <initialSeverity>0.01</initialSeverity>
    <tendable>false</tendable>
    <stages>
      <li>
        <label>Ventricular fibrillation</label>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li><capacity>BloodPumping</capacity><setMax>0.10</setMax></li> 
          <li><capacity>Consciousness</capacity><setMax>0.10</setMax></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.60</minSeverity>
        <label>Cardiac arrest</label>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li><capacity>BloodPumping</capacity><setMax>0.01</setMax></li> 
          <li><capacity>Breathing</capacity><setMax>0.01</setMax></li>
          <li><capacity>Consciousness</capacity><setMax>0.01</setMax></li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>CerebralHypoxia</defName>
    <label>Cerebral hypoxia</label>
    <description>Acute neurological damage caused by insufficient blood or oxygen supply to the brain. Consciousness decreases as hypoxia worsens, accompanied by irreversible brain damage, culminating in brain death.</description>
    <hediffClass>EmergencyExpanded.Hediff_CerebralHypoxia</hediffClass>
    <defaultLabelColor>(0.6, 0.4, 0.8)</defaultLabelColor>
    <maxSeverity>1.0</maxSeverity> 
    <initialSeverity>0.05</initialSeverity>
    <comps>
      <li Class="EmergencyExpanded.HediffCompProperties_CerebralHypoxia"/>
    </comps>
    <stages>
      <li>
        <label>Mild - Unconscious collapse</label>
        <capMods>
          <li><capacity>Consciousness</capacity><setMax>0.10</setMax></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.25</minSeverity>
        <label>Moderate - Comatose</label>
        <capMods>
          <li><capacity>Consciousness</capacity><setMax>0.08</setMax></li>
          <li><capacity>Talking</capacity><setMax>0.5</setMax></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.5</minSeverity>
        <label>Severe - Deep coma</label>
        <capMods>
          <li><capacity>Consciousness</capacity><setMax>0.05</setMax></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.7</minSeverity>
        <label>Extreme - Near brain death</label>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li><capacity>Consciousness</capacity><setMax>0.01</setMax></li> 
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>HypoxicBrainDamage</defName>
    <label>Hypoxic brain damage</label>
    <description>Permanent necrosis of brain tissue from severe cerebral hypoxia. Irreversibly impairs cognitive, speech, and motor capabilities.</description>
    <hediffClass>EmergencyExpanded.Hediff_HypoxicBrainDamage</hediffClass>
    <defaultLabelColor>(0.85, 0.3, 0.3)</defaultLabelColor>
    <maxSeverity>1.0</maxSeverity>
    <isBad>true</isBad>
    <stages>
      <li>
        <label>Mild neurological deficit</label>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>-0.05</offset></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.25</minSeverity>
        <label>Moderate neurological deficit</label>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>-0.15</offset></li>
          <li><capacity>Talking</capacity><offset>-0.15</offset></li>
          <li><capacity>Moving</capacity><offset>-0.10</offset></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.55</minSeverity>
        <label>Severe hemiplegia and aphasia</label>
        <capMods>
          <li><capacity>Consciousness</capacity><setMax>0.50</setMax></li>
          <li><capacity>Talking</capacity><setMax>0.10</setMax></li>
          <li><capacity>Moving</capacity><setMax>0.30</setMax></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.85</minSeverity>
        <label>Near total brain death</label>
        <capMods>
          <li><capacity>Consciousness</capacity><setMax>0.35</setMax></li>
          <li><capacity>Talking</capacity><setMax>0.00</setMax></li>
          <li><capacity>Moving</capacity><setMax>0.05</setMax></li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>VegetativeState</defName>
    <label>Brain death (Vegetative state)</label>
    <description>Irreversible extensive neuronal necrosis. The patient loses all higher brain functions, keeping only basic heartbeats and respiration via the brainstem. Cannot awaken without life support.</description>
    <hediffClass>EmergencyExpanded.Hediff_PercentageDisplay</hediffClass>
    <defaultLabelColor>(0.4, 0.4, 0.4)</defaultLabelColor>
    <isBad>true</isBad>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <setMax>0.01</setMax> 
          </li>
          <li>
            <capacity>Talking</capacity>
            <setMax>0.0</setMax>
          </li>
          <li>
            <capacity>Moving</capacity>
            <setMax>0.0</setMax>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <HediffDef ParentName="InjuryBase">
    <defName>MassiveBleeding</defName>
    <label>Massive bleeding</label>
    <labelNoun>massive bleeding wound</labelNoun>
    <description>Catastrophic hemorrhage caused by major vessel or arterial rupture. If not compressed or tourniqueted immediately, the pawn will die of hemorrhagic shock in a very short time.</description>
    <hediffClass>Hediff_Injury</hediffClass>
    <defaultLabelColor>(1.0, 0.2, 0.2)</defaultLabelColor> 
    <comps>
      <li Class="EmergencyExpanded.HediffCompProperties_MassiveBleeding" />
    </comps>
    <injuryProps>
      <painPerSeverity>0.02</painPerSeverity>
      <bleedRate>3.0</bleedRate> 
      <canMerge>false</canMerge>
      <destroyedLabel>ruptured blood vessel</destroyedLabel>
    </injuryProps>
  </HediffDef>

  <HediffDef>
    <defName>AdrenalineBoost</defName>
    <label>Adrenaline rush</label>
    <description>Powerful adrenaline response triggered by trauma, crisis, or injections. Boosts moving, manipulation, and vital capacities while blocking pain to prevent shock. Excess doses cause severe sympathetic overload, catecholamine storm, myocardial infarction, and acidosis.</description>
    <hediffClass>EmergencyExpanded.Hediff_PercentageDisplay</hediffClass>
    <defaultLabelColor>(0.9, 0.6, 0.2)</defaultLabelColor>
    <maxSeverity>3.0</maxSeverity>
    <initialSeverity>1.0</initialSeverity>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-2.0</severityPerDay>
      </li>
      <li Class="EmergencyExpanded.HediffCompProperties_AdrenalineBoost"/>
    </comps>
    <stages>
      <li>
        <label>Fading</label>
        <painFactor>0.95</painFactor>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>0.03</offset></li>
          <li><capacity>Moving</capacity><offset>0.05</offset></li>
          <li><capacity>Manipulation</capacity><offset>0.03</offset></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.26</minSeverity>
        <label>Stress surge</label>
        <painFactor>0.85</painFactor>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>0.07</offset></li>
          <li><capacity>Moving</capacity><offset>0.10</offset></li>
          <li><capacity>Manipulation</capacity><offset>0.07</offset></li>
          <li><capacity>BloodPumping</capacity><offset>0.10</offset></li>
          <li><capacity>Breathing</capacity><offset>0.10</offset></li>
        </capMods>
        <statOffsets>
          <MeleeDodgeChance>2.0</MeleeDodgeChance>
          <MeleeHitChance>1.0</MeleeHitChance>
          <ShootingAccuracyPawn>1.0</ShootingAccuracyPawn>
        </statOffsets>
      </li>
      <li>
        <minSeverity>0.51</minSeverity>
        <label>Cardio-boosted</label>
        <painFactor>0.75</painFactor>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>0.10</offset></li>
          <li><capacity>Moving</capacity><offset>0.15</offset></li>
          <li><capacity>Manipulation</capacity><offset>0.10</offset></li>
          <li><capacity>BloodPumping</capacity><offset>0.20</offset></li>
          <li><capacity>Breathing</capacity><offset>0.20</offset></li>
        </capMods>
        <statOffsets>
          <MeleeDodgeChance>3.5</MeleeDodgeChance>
          <MeleeHitChance>1.5</MeleeHitChance>
          <ShootingAccuracyPawn>1.5</ShootingAccuracyPawn>
        </statOffsets>
      </li>
      <li>
        <minSeverity>0.76</minSeverity>
        <label>Extreme breakthrough</label>
        <painFactor>0.50</painFactor>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>0.15</offset></li>
          <li><capacity>Moving</capacity><offset>0.20</offset></li>
          <li><capacity>Manipulation</capacity><offset>0.15</offset></li>
          <li><capacity>BloodPumping</capacity><offset>0.30</offset></li>
          <li><capacity>Breathing</capacity><offset>0.30</offset></li>
        </capMods>
        <statOffsets>
          <MeleeDodgeChance>5.0</MeleeDodgeChance>
          <MeleeHitChance>2.0</MeleeHitChance>
          <ShootingAccuracyPawn>2.0</ShootingAccuracyPawn>
        </statOffsets>
      </li>
      <li>
        <minSeverity>1.01</minSeverity>
        <label>Sympathetic overload - Overdose</label>
        <painFactor>0.70</painFactor>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>-0.10</offset></li>
          <li><capacity>Moving</capacity><offset>-0.05</offset></li>
          <li><capacity>Manipulation</capacity><offset>-0.15</offset></li>
          <li><capacity>BloodPumping</capacity><offset>0.10</offset></li> <!-- 开始受舒张期缩短和高后负荷影响，泵血效率停止增长并下滑 -->
          <li><capacity>Breathing</capacity><offset>0.10</offset></li>
        </capMods>
        <statOffsets>
          <MeleeHitChance>-2.0</MeleeHitChance>
          <ShootingAccuracyPawn>-2.0</ShootingAccuracyPawn>
        </statOffsets>
      </li>
      <li>
        <minSeverity>2.01</minSeverity>
        <label>Catecholamine storm - Fatal overdose</label>
        <painFactor>0.90</painFactor>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>-0.30</offset></li>
          <li><capacity>Moving</capacity><offset>-0.20</offset></li>
          <li><capacity>Manipulation</capacity><offset>-0.40</offset></li>
          <li><capacity>BloodPumping</capacity><offset>-0.40</offset></li> <!-- 急性心力衰竭 / 心室充盈严重受限，循环崩溃 -->
          <li><capacity>Breathing</capacity><offset>-0.30</offset></li>    <!-- 心源性肺水肿，换气障碍 -->
        </capMods>
        <statOffsets>
          <MeleeHitChance>-4.0</MeleeHitChance>
          <ShootingAccuracyPawn>-4.0</ShootingAccuracyPawn>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>AdrenalineCrash</defName>
    <label>Adrenaline crash</label>
    <description>The fatigue and dehydration phase following an adrenaline rush. Due to extreme exertion and lactic acid buildup, moving, manipulation, and consciousness drop significantly, and inflammatory responses make pain receptors highly sensitive.</description>
    <hediffClass>EmergencyExpanded.Hediff_PercentageDisplay</hediffClass>
    <defaultLabelColor>(0.5, 0.4, 0.4)</defaultLabelColor>
    <maxSeverity>1.0</maxSeverity>
    <initialSeverity>1.0</initialSeverity>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-8.0</severityPerDay>
      </li>
    </comps>
    <stages>
      <li>
        <label>Recovering</label>
        <painOffset>0.05</painOffset>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>-0.02</offset></li>
          <li><capacity>Moving</capacity><offset>-0.05</offset></li>
          <li><capacity>Manipulation</capacity><offset>-0.05</offset></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.5</minSeverity>
        <label>Severe fatigue crash</label>
        <painOffset>0.10</painOffset>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>-0.05</offset></li>
          <li><capacity>Moving</capacity><offset>-0.10</offset></li>
          <li><capacity>Manipulation</capacity><offset>-0.10</offset></li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <HediffDef ParentName="InjuryBase">
    <defName>EE_ClosedFracture</defName>
    <label>Closed fracture</label>
    <labelNoun>closed fracture</labelNoun>
    <description>Bone fracture without skin breach. Causes intense pain and severe functional impairment. Movement without immobilization causes secondary soft tissue damage and risks malunion.</description>
    <hediffClass>EmergencyExpanded.Hediff_Fracture</hediffClass>
    <displayWound>false</displayWound>
    <injuryProps>
      <painPerSeverity>0.04</painPerSeverity>
      <canMerge>false</canMerge>
      <destroyedLabel>shattered</destroyedLabel>
    </injuryProps>
  </HediffDef>

  <HediffDef ParentName="InjuryBase">
    <defName>EE_OpenFracture</defName>
    <label>Open fracture</label>
    <labelNoun>open fracture</labelNoun>
    <description>Bone fracture with bone fragments piercing the skin. Accompanied by intense pain, hemorrhage, and an extremely high risk of infection. Requires immediate field splinting and surgery.</description>
    <hediffClass>EmergencyExpanded.Hediff_Fracture</hediffClass>
    <comps>
      <li Class="HediffCompProperties_TendDuration">
        <labelTendedWell>bandaged</labelTendedWell>
        <labelTendedWellInner>sutured</labelTendedWellInner>
        <labelSolidTendedWell>treated</labelSolidTendedWell>
      </li>
      <li Class="HediffCompProperties_Infecter">
        <infectionChance>0.60</infectionChance>
      </li>
    </comps>
    <injuryProps>
      <painPerSeverity>0.06</painPerSeverity>
      <bleedRate>1.5</bleedRate>
      <canMerge>false</canMerge>
      <destroyedLabel>shattered</destroyedLabel>
    </injuryProps>
  </HediffDef>

  <HediffDef>
    <defName>EE_Malunion</defName>
    <label>Malunion</label>
    <description>Fracture healing in an abnormal position due to lack of proper reduction or immobilization. Permanently decreases limb efficiency and causes chronic pain. Can only be corrected via osteotomy surgery.</description>
    <hediffClass>EmergencyExpanded.Hediff_PercentageDisplay</hediffClass>
    <defaultLabelColor>(0.8, 0.4, 0.4)</defaultLabelColor>
    <stages>
      <li>
        <painOffset>0.10</painOffset>
        <partEfficiencyOffset>-0.30</partEfficiencyOffset>
      </li>
    </stages>
  </HediffDef>
  <HediffDef>
    <defName>Coagulopathy</defName>
    <label>Coagulopathy</label>
    <description>A component of the lethal triad triggered by trauma, blood loss, hypothermia, and acidosis. Thrombin activity is severely suppressed, making wounds extremely difficult to clot and accelerating blood loss.</description>
    <hediffClass>EmergencyExpanded.Hediff_PercentageDisplay</hediffClass>
    <defaultLabelColor>(0.8, 0.2, 0.2)</defaultLabelColor>
    <maxSeverity>1.0</maxSeverity>
    <initialSeverity>0.1</initialSeverity>
    <comps>
      <li Class="EmergencyExpanded.HediffCompProperties_Coagulopathy" />
    </comps>
    <stages>
      <li>
        <label>Mild</label>
        <statOffsets>
          <MedicalTendQuality>-0.15</MedicalTendQuality>
        </statOffsets>
      </li>
      <li>
        <minSeverity>0.4</minSeverity>
        <label>Moderate</label>
        <statOffsets>
          <MedicalTendQuality>-0.3</MedicalTendQuality>
        </statOffsets>
      </li>
      <li>
        <minSeverity>0.7</minSeverity>
        <label>Severe</label>
        <lifeThreatening>true</lifeThreatening>
        <statOffsets>
          <MedicalTendQuality>-0.5</MedicalTendQuality>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>SIRS</defName>
    <label>SIRS</label>
    <description>Systemic Inflammatory Response Syndrome. A massive cytokine release triggered by extensive tissue damage, causing systemic capillary dilation and permeability. Precursor to MODS.</description>
    <hediffClass>EmergencyExpanded.Hediff_PercentageDisplay</hediffClass>
    <defaultLabelColor>(0.8, 0.4, 0.1)</defaultLabelColor>
    <maxSeverity>1.0</maxSeverity>
    <initialSeverity>0.1</initialSeverity>
    <comps>
      <li Class="EmergencyExpanded.HediffCompProperties_SIRS" />
    </comps>
    <stages>
      <li>
        <label>Latent</label>
        <becomeVisible>false</becomeVisible>
      </li>
      <li>
        <minSeverity>0.15</minSeverity>
        <label>Early</label>
        <capMods>
          <li><capacity>BloodPumping</capacity><offset>-0.1</offset></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.4</minSeverity>
        <label>Progressive</label>
        <capMods>
          <li><capacity>BloodPumping</capacity><offset>-0.2</offset></li>
          <li><capacity>Consciousness</capacity><offset>-0.1</offset></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.7</minSeverity>
        <label>Late (Microcirculatory failure)</label>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li><capacity>BloodPumping</capacity><setMax>0.6</setMax></li>
          <li><capacity>Consciousness</capacity><setMax>0.6</setMax></li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>MultipleOrganFailure</defName>
    <label>MODS</label>
    <description>Multiple Organ Dysfunction Syndrome. Irreversible extensive necrosis of vital organs due to prolonged hypoperfusion and microcirculatory collapse. Leads to sequential organ shutdown and death if circulation is not restored.</description>
    <hediffClass>EmergencyExpanded.Hediff_HiddenMultipleOrganFailure</hediffClass>
    <defaultLabelColor>(0.6, 0.2, 0.8)</defaultLabelColor>
    <maxSeverity>1.0</maxSeverity>
    <initialSeverity>0.1</initialSeverity>
    <comps>
      <li Class="EmergencyExpanded.HediffCompProperties_MODS">
        <severityIncreasePerDay>3.0</severityIncreasePerDay>
        <severityDecreasePerDay>2.0</severityDecreasePerDay>
      </li>
    </comps>
    <stages>
      <li>
        <label>Stage I</label>
        <capMods>
          <li><capacity>BloodFiltration</capacity><offset>-0.2</offset></li>
          <li><capacity>Metabolism</capacity><offset>-0.2</offset></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.4</minSeverity>
        <label>Stage II</label>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li><capacity>BloodFiltration</capacity><setMax>0.5</setMax></li>
          <li><capacity>Metabolism</capacity><setMax>0.5</setMax></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.8</minSeverity>
        <label>Terminal stage</label>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li><capacity>BloodFiltration</capacity><setMax>0.1</setMax></li>
          <li><capacity>Metabolism</capacity><setMax>0.1</setMax></li>
          <li><capacity>BloodPumping</capacity><setMax>0.2</setMax></li>
          <li><capacity>Consciousness</capacity><setMax>0.1</setMax></li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>EE_CPR_Receiving</defName>
    <label>Receiving CPR</label>
    <description>Pawn is receiving cardiopulmonary resuscitation (CPR). Chest compressions and artificial ventilation provide basic perfusion, freezing cerebral hypoxia/brain damage progression and boosting defibrillation success. Fades quickly if stopped.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(0.2, 0.8, 0.8)</defaultLabelColor>
    <maxSeverity>1.0</maxSeverity>
    <initialSeverity>1.0</initialSeverity>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>120</disappearsAfterTicks> <!-- 2秒无按压自动消退 -->
        <showRemainingTime>false</showRemainingTime>
      </li>
    </comps>
  </HediffDef>

  <!-- ======================== TXA 促凝血状态 (单 Hediff) ======================== -->
  <HediffDef>
    <defName>EE_TxaActive</defName>
    <label>TXA active</label>
    <description>Tranexamic acid (TXA) is active. Stabilizes blood clots by inhibiting fibrinolysis, halving physical bleeding rate, preventing coagulopathy, and reducing massive bleeding chances. Overdose risks microvascular embolisms and muscle spasms.</description>
    <hediffClass>EmergencyExpanded.Hediff_PercentageDisplay</hediffClass>
    <defaultLabelColor>(0.8, 0.4, 0.1)</defaultLabelColor>
    <maxSeverity>3.0</maxSeverity>
    <initialSeverity>1.0</initialSeverity>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-2.0</severityPerDay>
      </li>
      <li Class="EmergencyExpanded.HediffCompProperties_TxaEffect"/>
    </comps>
    <stages>
      <li>
        <label>Safe coagulation</label>
      </li>
      <li>
        <minSeverity>1.01</minSeverity>
        <label>Hypercoagulable accumulation - Overdose</label>
        <capMods>
          <li><capacity>Metabolism</capacity><offset>-0.10</offset></li>
          <li><capacity>Moving</capacity><offset>-0.05</offset></li>
        </capMods>
      </li>
      <li>
        <minSeverity>2.01</minSeverity>
        <label>Dangerous overdose - Critical</label>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li><capacity>Metabolism</capacity><offset>-0.20</offset></li>
          <li><capacity>Moving</capacity><offset>-0.15</offset></li>
          <li><capacity>Consciousness</capacity><offset>-0.10</offset></li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <!-- ======================== TXA 中毒诱发强直性抽搐 ======================== -->
  <HediffDef>
    <defName>EE_TxaSeizure</defName>
    <label>Tonic seizure (TXA toxicity)</label>
    <description>Excitatory neurotoxic epilepsy caused by excessive TXA levels blocking central GABA-A receptors. Induces generalized tonic muscle spasms, rendering the pawn unconscious and immobilized with intense muscle pain.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(0.9, 0.3, 0.3)</defaultLabelColor>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>4500~9000</disappearsAfterTicks> <!-- 1.25 到 2.5 小时 -->
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
    <stages>
      <li>
        <painOffset>0.40</painOffset>
        <capMods>
          <li><capacity>Consciousness</capacity><setMax>0.10</setMax></li>
          <li><capacity>Moving</capacity><setMax>0.00</setMax></li>
          <li><capacity>Manipulation</capacity><setMax>0.00</setMax></li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <!-- ======================== 吗啡生效中 (单 Hediff) ======================== -->
  <HediffDef>
    <defName>EE_MorphineActive</defName>
    <label>Morphine active</label>
    <description>Morphine is active. Blocks pain, slows progression of myocardial infarction (by 30%), shock, and SIRS (by 40%), and increases bone setting/casting success rate by 15%. Causes mild drowsiness and slowed movement. Overdose risks severe respiratory depression, coma, or arrest.</description>
    <hediffClass>EmergencyExpanded.Hediff_PercentageDisplay</hediffClass>
    <defaultLabelColor>(0.6, 0.4, 0.8)</defaultLabelColor>
    <maxSeverity>3.0</maxSeverity>
    <initialSeverity>1.0</initialSeverity>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-2.0</severityPerDay>
      </li>
      <li Class="EmergencyExpanded.HediffCompProperties_MorphineEffect"/>
    </comps>
    <stages>
      <li>
        <label>Analgesic treatment</label>
        <painFactor>0.15</painFactor>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>-0.10</offset></li>
          <li><capacity>Moving</capacity><offset>-0.10</offset></li>
          <li><capacity>Manipulation</capacity><offset>-0.10</offset></li>
          <li><capacity>Breathing</capacity><offset>-0.10</offset></li>
        </capMods>
      </li>
      <li>
        <minSeverity>1.01</minSeverity>
        <label>Morphine overdose - CNS depression</label>
        <painFactor>0.05</painFactor>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>-0.30</offset></li>
          <li><capacity>Moving</capacity><offset>-0.25</offset></li>
          <li><capacity>Manipulation</capacity><offset>-0.20</offset></li>
          <li><capacity>Breathing</capacity><offset>-0.40</offset></li>
        </capMods>
      </li>
      <li>
        <minSeverity>2.01</minSeverity>
        <label>Morphine toxicity - Deep coma</label>
        <painFactor>0.00</painFactor>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li><capacity>Consciousness</capacity><setMax>0.10</setMax></li>
          <li><capacity>Moving</capacity><offset>-0.80</offset></li>
          <li><capacity>Manipulation</capacity><offset>-0.80</offset></li>
          <li><capacity>Breathing</capacity><offset>-0.75</offset></li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <!-- ======================== 吗啡中毒诱发呼吸骤停 ======================== -->
  <HediffDef>
    <defName>EE_MorphineRespiratoryArrest</defName>
    <label>Respiratory arrest (Morphine toxicity)</label>
    <description>Acute cessation of voluntary respiration caused by severe opioid overdose suppressing the brainstem respiratory center. Breathing capacity drops to 0%, inducing rapid cerebral hypoxia and acidosis. Immediate CPR is required while morphine metabolizes.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(0.9, 0.2, 0.2)</defaultLabelColor>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>3000~6000</disappearsAfterTicks> <!-- 50 到 100 分钟 -->
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
    <stages>
      <li>
        <capMods>
          <li><capacity>Breathing</capacity><setMax>0.00</setMax></li>
        </capMods>
      </li>
    </stages>
  </HediffDef>
</Defs>