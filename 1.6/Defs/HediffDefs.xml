<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef ParentName="InjuryBase">
    <defName>TissueHypoxia</defName>
    <label>组织缺氧</label>
    <labelNoun>缺氧组织</labelNoun>
    <description>由于严重缺氧和代谢性酸中毒导致的局部组织损伤。像冻伤一样，它会持续破坏组织扣减血量，如果不及早恢复血液循环，会导致部位永久脱落。</description>
    <hediffClass>Hediff_Injury</hediffClass>
    <initialSeverity>3.0</initialSeverity> 
    <injuryProps>
      <painPerSeverity>0.015</painPerSeverity>
      <averagePainPerSeverityPermanent>0.005</averagePainPerSeverityPermanent>
      <canMerge>true</canMerge> 
      <destroyedLabel>组织坏死</destroyedLabel>
      <destroyedOutLabel>组织坏死</destroyedOutLabel>
    </injuryProps>
  </HediffDef>

  <HediffDef>
    <defName>MetabolicAcidosis</defName>
    <label>代谢性酸中毒</label>
    <description>因组织灌注不足导致的酸碱平衡崩盘。系统一旦崩溃，酸中毒将持续恶化啃食机体。发展到晚期时，会引发不可逆的多脏器缺血衰竭并导致死亡。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(0.8, 0.8, 0.3)</defaultLabelColor>
    <maxSeverity>1.0</maxSeverity> <initialSeverity>0.1</initialSeverity>
    <makesSickThought>true</makesSickThought>
    <tendable>true</tendable>
    <comps>
      <li Class="HediffCompProperties_TendDuration">
        <baseTendDurationHours>12</baseTendDurationHours>
        <severityPerDayTended>-2.0</severityPerDayTended> 
      </li>
      <li Class="EmergencyExpanded.HediffCompProperties_Acidosis">
        <severityIncreasePerDay>6.0</severityIncreasePerDay>
        <severityDecreasePerDay>0.8</severityDecreasePerDay>
        <bloodPumpingThreshold>0.2</bloodPumpingThreshold>
        <hypoxiaDamage>2.5</hypoxiaDamage>
      </li>
    </comps>
    <stages>
      <li>
        <label>轻度</label>
        <capMods>
          <li><capacity>Breathing</capacity><offset>-0.2</offset></li>
          <li><capacity>BloodPumping</capacity><offset>-0.2</offset></li> 
        </capMods>
      </li>
      <li>
        <minSeverity>0.2</minSeverity>
        <label>中度</label>
        <painOffset>0.1</painOffset>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>-0.2</offset></li>
          <li><capacity>BloodPumping</capacity><offset>-0.2</offset></li> 
        </capMods>
      </li>
      <li>
        <minSeverity>0.5</minSeverity>
        <label>重度</label>
        <lifeThreatening>true</lifeThreatening>
        <painOffset>0.25</painOffset>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>-0.4</offset></li>
          <li><capacity>BloodPumping</capacity><offset>-0.4</offset></li> 
        </capMods>
        <hediffGivers>
          <li Class="HediffGiver_Random">
            <hediff>VentricularFibrillation</hediff>
            <mtbDays>0.05</mtbDays> 
          </li>
        </hediffGivers>
      </li>
      <li>
        <minSeverity>0.95</minSeverity>
        <label>极重度 - 多脏器衰竭</label> 
        <lifeThreatening>true</lifeThreatening>
        <painOffset>0.40</painOffset>
        <capMods>
          <li><capacity>Consciousness</capacity><setMax>0.1</setMax></li>
          <li><capacity>BloodPumping</capacity><setMax>0.15</setMax></li>
        </capMods>
        <hediffGivers>
          <li Class="HediffGiver_Random">
            <hediff>VentricularFibrillation</hediff>
            <mtbDays>0.02</mtbDays> 
          </li>
        </hediffGivers>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>VentricularFibrillation</defName>
    <label>致命心律失常</label>
    <description>心脏功能丧失。不仅无法泵血，还会导致全身组织极速缺氧坏死。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(0.9, 0.2, 0.2)</defaultLabelColor>
    <lethalSeverity>1.0</lethalSeverity> 
    <initialSeverity>0.1</initialSeverity>
    <tendable>true</tendable> 
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>8.0</severityPerDay> 
      </li>
      <li Class="HediffCompProperties_TendDuration">
        <baseTendDurationHours>1.5</baseTendDurationHours> 
        <severityPerDayTended>-10.0</severityPerDayTended> 
      </li>
    </comps>
    <stages>
      <li>
        <label>心室颤动</label>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li><capacity>BloodPumping</capacity><setMax>0.10</setMax></li> 
          <li><capacity>Consciousness</capacity><setMax>0.10</setMax></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.60</minSeverity>
        <label>心跳骤停</label>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li><capacity>BloodPumping</capacity><setMax>0.01</setMax></li> 
          <li><capacity>Breathing</capacity><setMax>0.01</setMax></li>
          <li><capacity>Consciousness</capacity><setMax>0.01</setMax></li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

<HediffDef>
    <defName>CerebralHypoxia</defName>
    <label>脑缺氧</label>
    <description>大脑供血或供氧不足导致的急性神经系统损伤。随着缺氧加剧，意识会逐渐丧失，并伴随不可逆的脑部器质性损伤。如果达到极限，将导致彻底的脑死亡。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(0.6, 0.4, 0.8)</defaultLabelColor>
    <maxSeverity>1.0</maxSeverity> 
    <initialSeverity>0.05</initialSeverity>
    <comps>
      <li Class="EmergencyExpanded.HediffCompProperties_CerebralHypoxia"/>
    </comps>
    <stages>
      <li>
        <label>轻度 - 意识模糊</label>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>-0.15</offset></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.3</minSeverity>
        <label>中度 - 神经紊乱</label>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>-0.4</offset></li>
          <li><capacity>Talking</capacity><offset>-0.3</offset></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.6</minSeverity>
        <label>重度 - 昏迷边缘</label>
        <capMods>
          <li><capacity>Consciousness</capacity><setMax>0.2</setMax></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.85</minSeverity>
        <label>极重度 - 深昏迷</label>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li><capacity>Consciousness</capacity><setMax>0.01</setMax></li> 
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>HypoxicBrainDamage</defName>
    <label>缺氧性脑损伤</label>
    <description>由于严重脑缺氧导致的不可逆脑组织永久性坏死。这会实质性地且不可逆地摧毁小人的认知、语言和运动运动能力。</description>
    <hediffClass>Hediff</hediffClass>
    <defaultLabelColor>(0.85, 0.3, 0.3)</defaultLabelColor>
    <maxSeverity>1.0</maxSeverity>
    <isBad>true</isBad>
    <stages>
      <li>
        <label>轻度神经功能缺损</label>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>-0.05</offset></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.25</minSeverity>
        <label>中度神经功能缺损</label>
        <capMods>
          <li><capacity>Consciousness</capacity><offset>-0.15</offset></li>
          <li><capacity>Talking</capacity><offset>-0.15</offset></li>
          <li><capacity>Moving</capacity><offset>-0.10</offset></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.55</minSeverity>
        <label>重度偏瘫与失语</label>
        <capMods>
          <li><capacity>Consciousness</capacity><setMax>0.50</setMax></li>
          <li><capacity>Talking</capacity><setMax>0.10</setMax></li>
          <li><capacity>Moving</capacity><setMax>0.30</setMax></li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.85</minSeverity>
        <label>濒临全面脑死亡</label>
        <capMods>
          <li><capacity>Consciousness</capacity><setMax>0.35</setMax></li>
          <li><capacity>Talking</capacity><setMax>0.00</setMax></li>
          <li><capacity>Moving</capacity><setMax>0.05</setMax></li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>VegetativeState</defName>
    <label>脑死亡 (植物状态)</label>
    <description>不可逆的广泛性脑神经元坏死。伤者失去了所有高级神经活动，仅依靠脑干维持最基础的心跳和呼吸。如果没有生命维持设备的干预，伤者永远无法醒来。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(0.4, 0.4, 0.4)</defaultLabelColor>
    <isBad>true</isBad>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <setMax>0.01</setMax> </li>
          <li>
            <capacity>Talking</capacity>
            <setMax>0.0</setMax>
          </li>
          <li>
            <capacity>Moving</capacity>
            <setMax>0.0</setMax>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

</Defs>