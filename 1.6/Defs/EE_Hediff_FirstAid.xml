<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <HediffDef>
    <defName>EE_AdrenalineStabilized</defName>
    <label>肾上腺素强制稳定</label>
    <description>强力维生药剂和酸碱缓冲合剂正在血液中激荡。在此状态存续的 12 游戏小时内，严重的代谢性酸中毒及致命心室颤动（心跳骤停）的病程恶化速度将被完全被冰冻暂缓。药效退去后病变将恢复正常流转。</description>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(0.2, 0.8, 0.8)</defaultLabelColor>
    <maxSeverity>1.0</maxSeverity>
    <initialSeverity>1.0</initialSeverity>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-2.0</severityPerDay> <!-- 持续 12 小时逐渐消退到 0 -->
      </li>
    </comps>
    <stages>
      <li>
        <label>冰冻稳态中</label>
      </li>
    </stages>
  </HediffDef>
</Defs>
