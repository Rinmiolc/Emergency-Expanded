<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- 生理盐水 (Saline/Antiseptic Irrigation) -->
  <ThingDef ParentName="ResourceBase">
    <defName>EE_Saline</defName>
    <label>Saline solution</label>
    <description>Used to irrigate wounds before bandaging, washing away dirt and foreign objects. Significantly reduces wound contamination to prevent infection. Not a formal medicine; only for first aid.</description>
    <graphicData>
      <texPath>Things/SalineBag</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>50</stackLimit>
    <statBases>
      <MaxHitPoints>40</MaxHitPoints>
      <MarketValue>5</MarketValue>
      <Mass>0.2</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <thingCategories>
      <li>Medicine</li>
    </thingCategories>
  </ThingDef>

  <!-- 广谱抗生素 (IV Broad-Spectrum Antibiotics) -->
  <ThingDef ParentName="ResourceBase">
    <defName>EE_BroadAntibiotics</defName>
    <label>Broad-spectrum antibiotics</label>
    <description>A powerful intravenous broad-spectrum antibiotic. Specifically used to treat active severe suppuration, sepsis, and other fatal infections. Not for prevention; highly effective during active infection stages.</description>
    <graphicData>
      <texPath>Things/Item/Resource/Medicine/MedicineIndustrial</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>25</stackLimit>
    <statBases>
      <MaxHitPoints>50</MaxHitPoints>
      <MarketValue>35</MarketValue>
      <Mass>0.1</Mass>
      <Flammability>0.5</Flammability>
      <Nutrition>0</Nutrition>
    </statBases>
    <thingCategories>
      <li>Medicine</li>
    </thingCategories>
    <ingestible>
      <preferability>NeverForNutrition</preferability>
      <foodType>Processed</foodType>
      <baseIngestTicks>120</baseIngestTicks>
      <chairSearchRadius>0</chairSearchRadius>
      <ingestSound>Ingest_Pill</ingestSound>
      <ingestHoldUsesTable>false</ingestHoldUsesTable>
      <ingestCommandString>Inject IV {0}</ingestCommandString>
      <ingestReportString>Injecting IV {0}.</ingestReportString>
      <outcomeDoers>
        <li Class="IngestionOutcomeDoer_GiveHediff">
          <hediffDef>EE_BroadAntibioticsHigh</hediffDef>
          <severity>1.0</severity>
        </li>
      </outcomeDoers>
    </ingestible>
  </ThingDef>

  <RecipeDef>
    <defName>Make_EE_Saline</defName>
    <label>Make saline solution</label>
    <description>Craft simple irrigation solution from water and herbal extracts.</description>
    <jobString>Making saline solution.</jobString>
    <workAmount>300</workAmount>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>MedicineHerbal</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>MedicineHerbal</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <EE_Saline>3</EE_Saline>
    </products>
    <recipeUsers>
      <li>DrugLab</li>
      <li>CraftingSpot</li>
    </recipeUsers>
  </RecipeDef>

  <RecipeDef>
    <defName>Make_EE_BroadAntibiotics</defName>
    <label>Make broad-spectrum antibiotics</label>
    <description>Synthesize potent broad-spectrum antibiotics from neutroamine at a drug lab.</description>
    <jobString>Making broad-spectrum antibiotics.</jobString>
    <workAmount>1200</workAmount>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>Neutroamine</li>
          </thingDefs>
        </filter>
        <count>2</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>MedicineHerbal</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Neutroamine</li>
        <li>MedicineHerbal</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <EE_BroadAntibiotics>1</EE_BroadAntibiotics>
    </products>
    <recipeUsers>
      <li>DrugLab</li>
    </recipeUsers>
    <researchPrerequisite>PenoxycylineProduction</researchPrerequisite>
  </RecipeDef>

</Defs>
