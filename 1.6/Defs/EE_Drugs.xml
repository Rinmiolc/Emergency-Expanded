  <!-- 医用吗啡注射器 (Medical Morphine Autoinjector) -->
  <ThingDef ParentName="MakeableDrugBase">
    <defName>EE_MorphineSyringe</defName>
    <label>Morphine autoinjector</label>
    <description>A battlefield autoinjector containing concentrated morphine. Fast to administer, it blocks over 85% of pain, wakes up pawns unconscious from pain shock, and slows the progression of myocardial infarction (by 30%), shock, and systemic inflammation (by 40%). It also sedates the patient, increasing bone setting or plaster casting alignment quality by 15%. Side effects include mild drowsiness and slowed movement. Overdose causes severe respiratory depression, coma, or respiratory arrest.</description>
