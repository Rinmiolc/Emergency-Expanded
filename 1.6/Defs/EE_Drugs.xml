<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <!-- 肾上腺素注射器 (Adrenaline Syringe) -->
  <ThingDef ParentName="MakeableDrugBase">
    <defName>EE_AdrenalineSyringe</defName>
    <label>Adrenaline autoinjector</label>
    <description>A battlefield autoinjector containing highly concentrated adrenaline. Fast to administer, it instantly boosts physical capabilities, strengthens heart rate, and blocks pain. It also clears previous adrenaline crash states. As a potent stress hormone, its decay triggers a severe fatigue crash. Consecutive injections can lead to fatal catecholamine storms and hypertensive crises.</description>
    <descriptionHyperlinks>
      <HediffDef>AdrenalineBoost</HediffDef>
    </descriptionHyperlinks>
    <graphicData>
      <texPath>Things/AdrenalineSyringe/adrenaline</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <rotatable>false</rotatable>
    <statBases>
      <WorkToMake>600</WorkToMake>
      <MarketValue>35</MarketValue>
      <Mass>0.05</Mass>
      <Flammability>0.7</Flammability>
    </statBases>
    <techLevel>Industrial</techLevel>
    <ingestible>
      <foodType>Processed</foodType>
      <drugCategory>Medical</drugCategory>
      <baseIngestTicks>60</baseIngestTicks>
      <chairSearchRadius>0</chairSearchRadius>
      <ingestSound>Ingest_Pill</ingestSound>
      <ingestHoldUsesTable>false</ingestHoldUsesTable>
      <ingestCommandString>Inject {0}</ingestCommandString>
      <ingestReportString>Injecting {0}.</ingestReportString>
      <outcomeDoers>
        <li Class="EmergencyExpanded.IngestionOutcomeDoer_AdrenalineSyringe">
          <toxicityHediff>AdrenalineBoost</toxicityHediff>
          <severityIncrement>1.0</severityIncrement>
          <maxSeverity>3.0</maxSeverity>
        </li>
      </outcomeDoers>
    </ingestible>
    <recipeMaker>
      <researchPrerequisite>MedicineProduction</researchPrerequisite>
      <recipeUsers>
        <li>DrugLab</li>
      </recipeUsers>
      <skillRequirements>
        <Medicine>4</Medicine>
        <Crafting>4</Crafting>
      </skillRequirements>
    </recipeMaker>
    <costList>
      <PsychoidLeaves>5</PsychoidLeaves>
      <Neutroamine>5</Neutroamine>
      <ComponentIndustrial>1</ComponentIndustrial>
    </costList>
    <comps>
      <li Class="CompProperties_Drug">
        <listOrder>1010</listOrder>
        <overdoseSeverityOffset>0.05~0.10</overdoseSeverityOffset>
      </li>
    </comps>
  </ThingDef>

  <!-- TXA 强效促凝血剂注射器 (TXA Autoinjector) -->
  <ThingDef ParentName="MakeableDrugBase">
    <defName>EE_TxaSyringe</defName>
    <label>TXA autoinjector</label>
