<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <RecipeDef>
    <defName>EE_Recipe_NeedleDecompression</defName>
    <label>Perform needle decompression</label>
    <description>Insert a needle into the pleural cavity to release trapped air, relieving tension pneumothorax. Requires medicine.</description>
    <workerClass>EmergencyExpanded.Recipe_NeedleDecompression</workerClass>
    <jobString>Performing needle decompression...</jobString>
    <workAmount>1000</workAmount>
    <hideBodyPartNames>false</hideBodyPartNames>
    <isViolation>false</isViolation>
    <targetsBodyPart>true</targetsBodyPart>
    <recipeUsers>
      <li>Human</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <categories>
            <li>Medicine</li>
          </categories>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <categories>
        <li>Medicine</li>
      </categories>
      <disallowedThingDefs>
        <li>EE_FirstAidKit</li>
        <li>EE_FirstAidBox</li>
      </disallowedThingDefs>
    </fixedIngredientFilter>
    <skillRequirements>
      <Medicine>6</Medicine>
    </skillRequirements>
  </RecipeDef>

</Defs>
