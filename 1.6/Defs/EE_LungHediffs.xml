<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef>
    <defName>EE_Pneumothorax</defName>
    <label>气胸</label>
    <description>空气进入胸膜腔，导致肺部部分或完全萎缩。这会严重影响呼吸并引起剧痛。如果发展为张力性气胸，且不立即进行胸腔穿刺减压，将会致命。</description>
    <hediffClass>EmergencyExpanded.Hediff_Pneumothorax</hediffClass>
    <defaultLabelColor>(0.8, 0.4, 0.4)</defaultLabelColor>
    <isBad>true</isBad>
    <tendable>false</tendable>
    <maxSeverity>1.0</maxSeverity>
    <comps>
      <li Class="HediffCompProperties_TendDuration">
        <baseTendDurationHours>24</baseTendDurationHours>
        <severityPerDayTended>-0.2</severityPerDayTended>
      </li>
    </comps>
    <stages>
      <li>
        <label>轻度</label>
        <minSeverity>0.0</minSeverity>
        <partEfficiencyOffset>-0.2</partEfficiencyOffset>
        <painOffset>0.1</painOffset>
      </li>
      <li>
        <label>中度</label>
        <minSeverity>0.2</minSeverity>
        <partEfficiencyOffset>-0.5</partEfficiencyOffset>
        <painOffset>0.25</painOffset>
        <capMods>
          <li>
            <capacity>Breathing</capacity>
            <offset>-0.15</offset>
          </li>
        </capMods>
      </li>
      <li>
        <label>张力性气胸</label>
        <minSeverity>0.6</minSeverity>
        <partEfficiencyOffset>-0.9</partEfficiencyOffset>
        <painOffset>0.5</painOffset>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li>
            <capacity>Breathing</capacity>
            <offset>-0.15</offset>
          </li>
          <li>
            <capacity>Consciousness</capacity>
            <setMax>0.8</setMax>
          </li>
        </capMods>
      </li>
      <li>
        <label>肺萎缩</label>
        <minSeverity>1.0</minSeverity>
        <partEfficiencyOffset>-1.0</partEfficiencyOffset>
        <painOffset>0.6</painOffset>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li>
            <capacity>Breathing</capacity>
            <offset>-0.25</offset>
          </li>
          <li>
            <capacity>Consciousness</capacity>
            <setMax>0.5</setMax>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

</Defs>
