<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef>
    <defName>EE_Pneumothorax</defName>
    <label>Pneumothorax</label>
    <description>Air entering the pleural cavity, causing partial or complete lung collapse. Severely impairs breathing and causes acute pain. If it develops into a tension pneumothorax and is not decompressed immediately, it will be fatal.</description>
    <hediffClass>EmergencyExpanded.Hediff_Pneumothorax</hediffClass>
    <defaultLabelColor>(0.85, 0.47, 0.14)</defaultLabelColor>
    <isBad>true</isBad>
    <tendable>true</tendable>
    <maxSeverity>1.0</maxSeverity>
    <comps>
      <li Class="HediffCompProperties_TendDuration">
        <baseTendDurationHours>12</baseTendDurationHours>
      </li>
    </comps>
    <stages>
      <li>
        <label>Minor</label>
        <minSeverity>0.0</minSeverity>
        <partEfficiencyOffset>-0.2</partEfficiencyOffset>
        <painOffset>0.1</painOffset>
      </li>
      <li>
        <label>Moderate</label>
        <minSeverity>0.2</minSeverity>
        <partEfficiencyOffset>-0.5</partEfficiencyOffset>
        <painOffset>0.25</painOffset>
        <capMods>
          <li>
            <capacity>Breathing</capacity>
            <offset>-0.15</offset>
          </li>
        </capMods>
      </li>
      <li>
        <label>Tension pneumothorax</label>
        <minSeverity>0.6</minSeverity>
        <partEfficiencyOffset>-0.9</partEfficiencyOffset>
        <painOffset>0.5</painOffset>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li>
            <capacity>Breathing</capacity>
            <offset>-0.15</offset>
          </li>
          <li>
            <capacity>Consciousness</capacity>
            <setMax>0.8</setMax>
          </li>
        </capMods>
      </li>
      <li>
        <label>Lung collapse</label>
        <minSeverity>1.0</minSeverity>
        <partEfficiencyOffset>-1.0</partEfficiencyOffset>
        <painOffset>0.6</painOffset>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li>
            <capacity>Breathing</capacity>
            <offset>-0.25</offset>
          </li>
          <li>
            <capacity>Consciousness</capacity>
            <setMax>0.5</setMax>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

</Defs>
