<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- ======================== 心脏 (Heart) ======================== -->
  <HediffDef>
    <defName>EE_MyocardialIschemia</defName>
    <label>Myocardial ischemia</label>
    <labelNoun>myocardial ischemia</labelNoun>
    <description>Acute ischemia of cardiac muscles due to insufficient perfusion. If unresolved, it progresses to heart failure or triggers sudden myocardial infarction.</description>
    <hediffClass>EmergencyExpanded.Hediff_PercentageDisplay</hediffClass>
    <defaultLabelColor>(0.85, 0.47, 0.14)</defaultLabelColor>
    <scenarioCanAdd>false</scenarioCanAdd>
    <maxSeverity>1.0</maxSeverity>
    <stages>
      <li>
        <label>Silent</label>
        <becomeVisible>false</becomeVisible>
      </li>
      <li>
        <minSeverity>0.2</minSeverity>
        <label>Mild</label>
        <partEfficiencyOffset>-0.15</partEfficiencyOffset>
      </li>
      <li>
        <minSeverity>0.5</minSeverity>
        <label>Severe</label>
        <partEfficiencyOffset>-0.35</partEfficiencyOffset>
        <painOffset>0.15</painOffset>
      </li>
      <li>
        <minSeverity>0.8</minSeverity>
        <label>Critical</label>
        <partEfficiencyOffset>-0.60</partEfficiencyOffset>
        <painOffset>0.25</painOffset>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>EE_HeartFailure</defName>
    <label>Heart failure</label>
    <labelNoun>heart failure</labelNoun>
    <description>Irreversible cardiac muscle failure. The heart's extremely weak pumping capacity is unable to maintain circulation. Can only be resolved by organ transplant.</description>
    <hediffClass>EmergencyExpanded.Hediff_PercentageDisplay</hediffClass>
    <defaultLabelColor>(0.83, 0.25, 0.25)</defaultLabelColor>
    <scenarioCanAdd>false</scenarioCanAdd>
    <stages>
      <li>
        <partEfficiencyOffset>-0.85</partEfficiencyOffset>
        <capMods>
          <li>
            <capacity>BloodPumping</capacity>
            <setMax>0.2</setMax>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <!-- ======================== 肺部 (Lungs) ======================== -->
  <HediffDef>
    <defName>EE_AcuteRespiratoryDistress</defName>
    <label>Acute respiratory distress</label>
    <labelNoun>ARDS</labelNoun>
    <description>Acute Respiratory Distress Syndrome (ARDS). Alveoli fill with fluid, severely degrading oxygen exchange and lung compliance, with a high chance of spontaneous pneumothorax.</description>
    <hediffClass>EmergencyExpanded.Hediff_PercentageDisplay</hediffClass>
    <defaultLabelColor>(0.85, 0.47, 0.14)</defaultLabelColor>
    <scenarioCanAdd>false</scenarioCanAdd>
    <maxSeverity>1.0</maxSeverity>
    <stages>
      <li>
        <label>Silent</label>
        <becomeVisible>false</becomeVisible>
      </li>
      <li>
        <minSeverity>0.2</minSeverity>
        <label>Mild</label>
        <partEfficiencyOffset>-0.15</partEfficiencyOffset>
      </li>
      <li>
        <minSeverity>0.5</minSeverity>
        <label>Severe</label>
        <partEfficiencyOffset>-0.40</partEfficiencyOffset>
      </li>
      <li>
        <minSeverity>0.8</minSeverity>
        <label>Critical</label>
        <partEfficiencyOffset>-0.65</partEfficiencyOffset>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>EE_RespiratoryFailure</defName>
    <label>Respiratory failure</label>
    <labelNoun>respiratory failure</labelNoun>
    <description>Irreversible respiratory failure. Lungs are severely fibrosed and completely unable to exchange gases. Can only be resolved by organ transplant.</description>
    <hediffClass>EmergencyExpanded.Hediff_PercentageDisplay</hediffClass>
    <defaultLabelColor>(0.83, 0.25, 0.25)</defaultLabelColor>
    <scenarioCanAdd>false</scenarioCanAdd>
    <stages>
      <li>
        <partEfficiencyOffset>-0.85</partEfficiencyOffset>
        <capMods>
          <li>
            <capacity>Breathing</capacity>
            <setMax>0.2</setMax>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <!-- ======================== 肝脏 (Liver) ======================== -->
  <HediffDef>
    <defName>EE_AcuteLiverInjury</defName>
    <label>Acute liver injury</label>
    <labelNoun>acute liver injury</labelNoun>
    <description>Acute ischemic liver damage (shock liver). Impairs filtration, metabolic functions, and coagulation factor synthesis.</description>
    <hediffClass>EmergencyExpanded.Hediff_PercentageDisplay</hediffClass>
    <defaultLabelColor>(0.85, 0.47, 0.14)</defaultLabelColor>
    <scenarioCanAdd>false</scenarioCanAdd>
    <maxSeverity>1.0</maxSeverity>
    <stages>
      <li>
        <label>Silent</label>
        <becomeVisible>false</becomeVisible>
      </li>
      <li>
        <minSeverity>0.2</minSeverity>
        <label>Mild</label>
        <partEfficiencyOffset>-0.20</partEfficiencyOffset>
      </li>
      <li>
        <minSeverity>0.5</minSeverity>
        <label>Severe</label>
        <partEfficiencyOffset>-0.45</partEfficiencyOffset>
      </li>
      <li>
        <minSeverity>0.8</minSeverity>
        <label>Critical</label>
        <partEfficiencyOffset>-0.70</partEfficiencyOffset>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>EE_LiverFailure</defName>
    <label>Liver failure</label>
    <labelNoun>liver failure</labelNoun>
    <description>Irreversible liver failure. Completely loses the ability to synthesize clotting factors and filter toxins, making wounds extremely hard to clot. Requires organ transplant.</description>
    <hediffClass>EmergencyExpanded.Hediff_PercentageDisplay</hediffClass>
    <defaultLabelColor>(0.83, 0.25, 0.25)</defaultLabelColor>
    <scenarioCanAdd>false</scenarioCanAdd>
    <stages>
      <li>
        <partEfficiencyOffset>-1.0</partEfficiencyOffset>
      </li>
    </stages>
  </HediffDef>

  <!-- ======================== 肾脏 (Kidneys) ======================== -->
  <HediffDef>
    <defName>EE_AcuteKidneyInjury</defName>
    <label>Acute kidney injury</label>
    <labelNoun>acute kidney injury</labelNoun>
    <description>Acute Kidney Injury (AKI) caused by renal hypoperfusion. Severely reduces blood filtration and acid excretion.</description>
    <hediffClass>EmergencyExpanded.Hediff_PercentageDisplay</hediffClass>
    <defaultLabelColor>(0.85, 0.47, 0.14)</defaultLabelColor>
    <scenarioCanAdd>false</scenarioCanAdd>
    <maxSeverity>1.0</maxSeverity>
    <stages>
      <li>
        <label>Silent</label>
        <becomeVisible>false</becomeVisible>
      </li>
      <li>
        <minSeverity>0.2</minSeverity>
        <label>Mild</label>
        <partEfficiencyOffset>-0.25</partEfficiencyOffset>
      </li>
      <li>
        <minSeverity>0.5</minSeverity>
        <label>Severe</label>
        <partEfficiencyOffset>-0.55</partEfficiencyOffset>
      </li>
      <li>
        <minSeverity>0.8</minSeverity>
        <label>Critical</label>
        <partEfficiencyOffset>-0.80</partEfficiencyOffset>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>EE_KidneyFailure</defName>
    <label>Kidney failure</label>
    <labelNoun>kidney failure</labelNoun>
    <description>Irreversible kidney failure. Completely loses excretion and filtration capacities, causing uncontrolled acidosis and toxic buildup. Requires organ transplant.</description>
    <hediffClass>EmergencyExpanded.Hediff_PercentageDisplay</hediffClass>
    <defaultLabelColor>(0.83, 0.25, 0.25)</defaultLabelColor>
    <scenarioCanAdd>false</scenarioCanAdd>
    <stages>
      <li>
        <partEfficiencyOffset>-1.0</partEfficiencyOffset>
      </li>
    </stages>
  </HediffDef>

</Defs>
