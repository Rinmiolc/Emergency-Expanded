<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef>
    <defName>EE_Shock</defName>
    <label>休克</label>
    <labelNoun>休克</labelNoun>
    <description>全身有效循环血量锐减导致微循环灌流严重不足的综合征。这并非一种独立的疾病，而是失血、败血症、大面积烧伤等致命创伤发展到晚期的共同致命路径。处于休克状态时，身体的核心器官将无法获得足够的氧气，如果不及时逆转，将导致多器官衰竭并致死。</description>
    <hediffClass>EmergencyExpanded.Hediff_Shock</hediffClass>
    <defaultLabelColor>(0.9, 0.4, 0.4)</defaultLabelColor>
    <comps>
      <!-- We use custom C# Hediff_Shock to update severity, no Immunizable comp needed unless we want natural healing which we handle in C# -->
    </comps>
    <stages>
      <li>
        <label>代偿期</label>
        <minSeverity>0.0</minSeverity>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.05</offset>
          </li>
          <li>
            <capacity>BloodPumping</capacity>
            <offset>-0.10</offset>
          </li>
        </capMods>
      </li>
      <li>
        <label>失代偿期</label>
        <minSeverity>0.4</minSeverity>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.25</offset>
          </li>
          <li>
            <capacity>BloodPumping</capacity>
            <offset>-0.30</offset>
          </li>
          <li>
            <capacity>Breathing</capacity>
            <offset>-0.15</offset>
          </li>
        </capMods>
      </li>
      <li>
        <label>不可逆期</label>
        <minSeverity>0.7</minSeverity>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.45</offset>
          </li>
          <li>
            <capacity>BloodPumping</capacity>
            <offset>-0.50</offset>
          </li>
          <li>
            <capacity>Breathing</capacity>
            <offset>-0.30</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

</Defs>
