<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef>
    <defName>EE_Shock</defName>
    <label>Shock</label>
    <labelNoun>shock</labelNoun>
    <description>A syndrome caused by severe drop in effective circulatory volume leading to microcirculatory hypoperfusion. Not an independent disease, but a common pathway for severe trauma, blood loss, sepsis, and burns. Impairs vital organ oxygenation, causing MODS and death if unresolved.</description>
    <hediffClass>EmergencyExpanded.Hediff_Shock</hediffClass>
    <defaultLabelColor>(0.9, 0.4, 0.4)</defaultLabelColor>
    <comps>
      <!-- We use custom C# Hediff_Shock to update severity, no Immunizable comp needed unless we want natural healing which we handle in C# -->
    </comps>
    <stages>
      <li>
        <label>Compensated stage</label>
        <minSeverity>0.0</minSeverity>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.05</offset>
          </li>
          <li>
            <capacity>BloodPumping</capacity>
            <offset>-0.10</offset>
          </li>
        </capMods>
      </li>
      <li>
        <label>Decompensated stage</label>
        <minSeverity>0.4</minSeverity>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.25</offset>
          </li>
          <li>
            <capacity>BloodPumping</capacity>
            <offset>-0.30</offset>
          </li>
          <li>
            <capacity>Breathing</capacity>
            <offset>-0.15</offset>
          </li>
        </capMods>
      </li>
      <li>
        <label>Irreversible stage</label>
        <minSeverity>0.7</minSeverity>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.45</offset>
          </li>
          <li>
            <capacity>BloodPumping</capacity>
            <offset>-0.50</offset>
          </li>
          <li>
            <capacity>Breathing</capacity>
            <offset>-0.30</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

</Defs>
