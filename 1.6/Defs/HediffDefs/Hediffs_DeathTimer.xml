<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef>
    <defName>EE_BiologicalDeathTimer</defName>
    <label>Biological death countdown</label>
    <description>The body has completely lost respiratory and circulatory function, and the central nervous system is dying. Cells are rapidly dying from hypoxia. When the countdown reaches zero, irreversible biological death occurs. CPR suspends this countdown.</description>
    <hediffClass>EmergencyExpanded.Hediff_PercentageDisplay</hediffClass>
    <defaultLabelColor>(0.8, 0.2, 0.2)</defaultLabelColor>
    <maxSeverity>1.0</maxSeverity>
    <initialSeverity>0.01</initialSeverity>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>6.0</severityPerDay> <!-- 4小时达到1.0 -->
      </li>
      <li Class="EmergencyExpanded.HediffCompProperties_BiologicalDeathTimer" />
    </comps>
    <stages>
      <li>
        <label>Loss of brainstem function</label>
        <becomeVisible>false</becomeVisible>
      </li>
      <li>
        <minSeverity>0.5</minSeverity>
        <label>Widespread tissue necrosis</label>
        <becomeVisible>false</becomeVisible>
      </li>
      <li>
        <minSeverity>0.9</minSeverity>
        <label>Critical threshold</label>
        <becomeVisible>false</becomeVisible>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>EE_BiologicalDeath</defName>
    <label>Biological death</label>
    <description>Absolute cellular death occurring after prolonged absence of circulation and respiration. All resuscitation measures are futile.</description>
    <hediffClass>Hediff</hediffClass>
    <defaultLabelColor>(0.2, 0.2, 0.2)</defaultLabelColor>
    <initialSeverity>1.0</initialSeverity>
    <isBad>true</isBad>
    <stages>
      <li>
        <becomeVisible>false</becomeVisible>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li><capacity>Consciousness</capacity><setMax>0.0</setMax></li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>EE_DeclaredDead</defName>
    <label>Declared dead</label>
    <description>Formally declared dead. Rescuers have abandoned all resuscitation attempts on this non-viable body.</description>
    <hediffClass>Hediff</hediffClass>
    <defaultLabelColor>(0.2, 0.2, 0.2)</defaultLabelColor>
    <initialSeverity>1.0</initialSeverity>
    <isBad>true</isBad>
    <stages>
      <li>
        <becomeVisible>false</becomeVisible>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li><capacity>Consciousness</capacity><setMax>0.0</setMax></li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

</Defs>
