<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- 清创术 (Debridement Surgery) -->
  <RecipeDef ParentName="SurgeryFlesh">
    <defName>EE_Recipe_Debridement</defName>
    <label>Surgical debridement</label>
    <description>A surgical procedure to cut open the wound and thoroughly clean away necrotic tissue and deep debris. Instantly resets contamination to zero and removes necrosis, at the cost of minor cut damage to the part.</description>
    <workerClass>EmergencyExpanded.Recipe_Debridement</workerClass>
    <jobString>Performing surgical debridement.</jobString>
    <workAmount>1800</workAmount>
    <surgerySuccessChanceFactor>0.95</surgerySuccessChanceFactor>
    <deathOnFailedSurgeryChance>0.02</deathOnFailedSurgeryChance>
    <skillRequirements>
      <Medicine>6</Medicine>
    </skillRequirements>
    <ingredients>
      <li>
        <filter>
          <categories>
            <li>Medicine</li>
          </categories>
        </filter>
        <count>1</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>EE_Saline</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <categories>
        <li>Medicine</li>
      </categories>
      <thingDefs>
        <li>EE_Saline</li>
      </thingDefs>
    </fixedIngredientFilter>
    <recipeUsers>
      <li>Human</li>
    </recipeUsers>
  </RecipeDef>
  <!-- 伤口冲洗术 (Wound Irrigation) -->
  <RecipeDef ParentName="SurgeryFlesh">
    <defName>EE_Recipe_Irrigation</defName>
    <label>Wound irrigation</label>
    <description>Thoroughly cleanses the wound of debris and environmental contaminants using sterile solution. Resets contamination to zero, preventing suppuration and necrosis. Requires no anesthesia, but needs basic medical knowledge.</description>
    <workerClass>EmergencyExpanded.Recipe_Irrigation</workerClass>
    <jobString>Irrigating wound.</jobString>
    <workAmount>600</workAmount> <!-- 比清创术快很多 -->
    <surgerySuccessChanceFactor>1.2</surgerySuccessChanceFactor> <!-- 几乎不会失败 -->
    <deathOnFailedSurgeryChance>0</deathOnFailedSurgeryChance>
    <skillRequirements>
      <Medicine>3</Medicine> <!-- 门槛更低 -->
    </skillRequirements>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>EE_Saline</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>EE_Saline</li>
      </thingDefs>
    </fixedIngredientFilter>
    <recipeUsers>
      <li>Human</li>
    </recipeUsers>
  </RecipeDef>

</Defs>
