<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- 传统正骨术 (Traditional Bone Setting) -->
  <RecipeDef ParentName="SurgeryFlesh">
    <defName>EE_Recipe_TraditionalBoneSetting</defName>
    <label>Traditional bone setting</label>
    <description>Use manual reduction and simple splints with herbal poultices to immobilize closed fractures. Requires strict bed rest; moving early will break the setting and cause malunion.</description>
    <workerClass>EmergencyExpanded.Recipe_BoneSetting</workerClass>
    <jobString>Performing traditional bone setting.</jobString>
    <workAmount>1500</workAmount>
    <surgerySuccessChanceFactor>1.00</surgerySuccessChanceFactor>
    <deathOnFailedSurgeryChance>0.01</deathOnFailedSurgeryChance>
    <skillRequirements>
      <Medicine>4</Medicine>
    </skillRequirements>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>MedicineHerbal</li>
            <li>MedicineIndustrial</li>
            <li>MedicineUltratech</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>WoodLog</li>
          </thingDefs>
        </filter>
        <count>5</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>MedicineHerbal</li>
        <li>MedicineIndustrial</li>
        <li>MedicineUltratech</li>
        <li>WoodLog</li>
      </thingDefs>
    </fixedIngredientFilter>
    <recipeUsers>
      <li>Human</li>
    </recipeUsers>
  </RecipeDef>

  <!-- 医用石膏固定术 (Plaster Casting) -->
  <RecipeDef ParentName="SurgeryFlesh">
    <defName>EE_Recipe_PlasterCasting</defName>
    <label>Plaster casting</label>
    <description>Manually reduce the fracture and apply rigid plaster casting. Plaster provides excellent mechanical rigidity, completely preventing secondary injury and malunion, while allowing moderate mobility.</description>
    <workerClass>EmergencyExpanded.Recipe_PlasterCasting</workerClass>
    <jobString>Applying plaster cast.</jobString>
    <workAmount>1200</workAmount>
    <surgerySuccessChanceFactor>1.00</surgerySuccessChanceFactor>
    <deathOnFailedSurgeryChance>0.01</deathOnFailedSurgeryChance>
    <skillRequirements>
      <Medicine>6</Medicine>
    </skillRequirements>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>MedicineHerbal</li>
            <li>MedicineIndustrial</li>
            <li>MedicineUltratech</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>EE_PlasterBandage</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>MedicineHerbal</li>
        <li>MedicineIndustrial</li>
        <li>MedicineUltratech</li>
        <li>EE_PlasterBandage</li>
      </thingDefs>
    </fixedIngredientFilter>
    <recipeUsers>
      <li>Human</li>
    </recipeUsers>
  </RecipeDef>

  <!-- 切开复位内固定术 (ORIF Surgery) -->
  <RecipeDef ParentName="SurgeryFlesh">
    <defName>EE_Recipe_ORIF</defName>
    <label>ORIF surgery</label>
    <description>Open Reduction Internal Fixation (ORIF) surgery. Incises soft tissue and secures fractured bone with plates and screws. Ideal for severe open or comminuted fractures. Requires no bed rest and heals rapidly without complications.</description>
    <workerClass>EmergencyExpanded.Recipe_ORIF</workerClass>
    <jobString>Performing ORIF surgery.</jobString>
    <workAmount>3000</workAmount>
    <surgerySuccessChanceFactor>0.95</surgerySuccessChanceFactor>
    <deathOnFailedSurgeryChance>0.05</deathOnFailedSurgeryChance>
    <skillRequirements>
      <Medicine>8</Medicine>
    </skillRequirements>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>MedicineIndustrial</li>
            <li>MedicineUltratech</li>
          </thingDefs>
        </filter>
        <count>2</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>MedicineIndustrial</li>
        <li>MedicineUltratech</li>
        <li>ComponentIndustrial</li>
      </thingDefs>
    </fixedIngredientFilter>
    <recipeUsers>
      <li>Human</li>
    </recipeUsers>
  </RecipeDef>

  <!-- 畸形接骨重折术 (Osteotomy) -->
  <RecipeDef ParentName="SurgeryFlesh">
    <defName>EE_Recipe_Osteotomy</defName>
    <label>Osteotomy</label>
    <description>Use surgical knives and bone saws to intentionally re-fracture malunited bones, clearing callus tissue and reverting the limb to an open fracture state for proper resetting.</description>
    <workerClass>EmergencyExpanded.Recipe_Osteotomy</workerClass>
    <jobString>Performing osteotomy.</jobString>
    <workAmount>3500</workAmount>
    <surgerySuccessChanceFactor>0.90</surgerySuccessChanceFactor>
    <deathOnFailedSurgeryChance>0.08</deathOnFailedSurgeryChance>
    <skillRequirements>
      <Medicine>10</Medicine>
    </skillRequirements>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>MedicineIndustrial</li>
            <li>MedicineUltratech</li>
          </thingDefs>
        </filter>
        <count>2</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>MedicineIndustrial</li>
        <li>MedicineUltratech</li>
      </thingDefs>
    </fixedIngredientFilter>
    <recipeUsers>
      <li>Human</li>
    </recipeUsers>
  </RecipeDef>

</Defs>
