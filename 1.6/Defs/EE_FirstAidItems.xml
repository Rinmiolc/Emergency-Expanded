<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- 急救包 (First Aid Kit) -->
  <ThingDef ParentName="ResourceBase">
    <defName>EE_HerbalFirstAidKit</defName>
    <label>急救包</label>
    <description>内含粗制草药提取液、简易压迫绷带和固定板。专为战地就地抢救设计，包扎速度极快且完全不受野外无医疗床的工作量惩罚，但由于药品条件简陋，处理伤口的品质（Tend Quality）较低。不能用于常规的外科手术。对于大出血，一个急救包最多可尝试包扎 5 次。</description>
    <graphicData>
      <texPath>Things/Item/FirstAid/FirstAidKit</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>25</stackLimit>
    <statBases>
      <MaxHitPoints>60</MaxHitPoints>
      <MarketValue>12</MarketValue>
      <Mass>0.15</Mass>
      <Flammability>1.0</Flammability>
    </statBases>
    <thingCategories>
      <li>Medicine</li>
    </thingCategories>
  </ThingDef>

  <!-- 急救箱 (First Aid Box) -->
  <ThingDef ParentName="ResourceBase">
    <defName>EE_FirstAidKit</defName>
    <label>急救箱</label>
    <description>标准军用战地急救箱，内含快速凝血粉、无菌压力绷带、可吸收缝合线和强效镇痛针。在混乱的枪战现场使用速度极快，且在野外就地抢救时没有任何速度惩罚，是封堵四肢和躯干大出血的核心耗材。不能用于基地的常规手术。对于大出血，一个急救箱最多可尝试包扎 10 次。</description>
    <graphicData>
      <texPath>Things/Item/FirstAid/FirstAidBox</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>20</stackLimit>
    <statBases>
      <MaxHitPoints>85</MaxHitPoints>
      <MarketValue>28</MarketValue>
      <Mass>0.28</Mass>
      <Flammability>0.8</Flammability>
    </statBases>
    <thingCategories>
      <li>Medicine</li>
    </thingCategories>
  </ThingDef>

  <!-- 战术止血带 (Tourniquet) -->
  <ThingDef ParentName="ResourceBase">
    <defName>EE_Tourniquet</defName>
    <label>战术止血带</label>
    <description>高强度单手便携式弹力止血带。只能在四肢受伤时绑扎。施用速度快至毫秒级别，使用后能瞬间将目标四肢上的所有大出血伤口包扎止血，作为战场续命的强力工具，无需耗费漫长的常规包扎读条。</description>
    <graphicData>
      <texPath>Things/Item/Resource/Medicine/MedicineHerbal</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>35</stackLimit>
    <statBases>
      <MaxHitPoints>50</MaxHitPoints>
      <MarketValue>9</MarketValue>
      <Mass>0.05</Mass>
      <Flammability>0.6</Flammability>
    </statBases>
    <thingCategories>
      <li>Medicine</li>
    </thingCategories>
  </ThingDef>

  <!-- 简易硬夹板 (Primitive Splint) -->
  <ThingDef ParentName="ResourceBase">
    <defName>EE_PrimitiveSplint</defName>
    <label>简易硬夹板</label>
    <description>由木条和粗质绷带制成的简易正骨夹板。可由医疗兵在野外直接施用以紧急固定受损骨骼，彻底免除移动造成的二次刺刺伤害，但无法保证完美的骨骼复位质量，依然有畸形愈合的风险。</description>
    <graphicData>
      <texPath>Things/Item/Resource/Medicine/MedicineHerbal</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>25</stackLimit>
    <statBases>
      <MaxHitPoints>50</MaxHitPoints>
      <MarketValue>8</MarketValue>
      <Mass>0.2</Mass>
      <Flammability>1.0</Flammability>
    </statBases>
    <thingCategories>
      <li>Medicine</li>
    </thingCategories>
  </ThingDef>

  <!-- 石膏绷带 (Plaster Bandage) -->
  <ThingDef ParentName="ResourceBase">
    <defName>EE_PlasterBandage</defName>
    <label>石膏绷带</label>
    <description>加入石膏粉的医用绷带。浸水后卷在患肢上可快速硬化，提供完美的刚性保守固定。只能在干净的病床上由医生通过“石膏固定术”施加，完全免除二次伤害并消除畸形愈合风险。</description>
    <graphicData>
      <texPath>Things/Item/Resource/Medicine/MedicineIndustrial</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>15</stackLimit>
    <statBases>
      <MaxHitPoints>60</MaxHitPoints>
      <MarketValue>18</MarketValue>
      <Mass>0.4</Mass>
      <Flammability>0.2</Flammability>
    </statBases>
    <thingCategories>
      <li>Medicine</li>
    </thingCategories>
  </ThingDef>

  <!-- 除颤仪 (Defibrillator) -->
  <ThingDef ParentName="ResourceBase">
    <defName>EE_Defibrillator</defName>
    <label>便携式除颤仪</label>
    <description>一台精密的便携式战地除颤仪，专门用于抢救发生心肌梗死与心室颤动（VF）的小人。除颤仪对前期的“心室颤动”（病情严重度低于60%）有极高成功率，而对晚期完全“心跳骤停”的小人，直接电击除颤成功率极低，除非有另一人正在对其实施心肺复苏（CPR）以建立微灌注，方能大幅提升成功率。使用时消耗除颤仪本身。除颤失败时，高能电流会对患者的躯体造成微量电击灼伤。</description>
    <graphicData>
      <texPath>Thing/Defibrillator</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>10</stackLimit>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <MarketValue>350</MarketValue>
      <Mass>1.5</Mass>
      <Flammability>0.4</Flammability>
    </statBases>
    <thingCategories>
      <li>Medicine</li>
    </thingCategories>
  </ThingDef>

  <!-- ================= 制作配方 ================= -->

  <RecipeDef>
    <defName>Make_EE_PrimitiveSplint</defName>
    <label>制作简易硬夹板</label>
    <description>使用木材和少量皮革或布料制作简易的正骨固定板。</description>
    <jobString>制作简易硬夹板中。</jobString>
    <workAmount>600</workAmount>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>WoodLog</li>
          </thingDefs>
        </filter>
        <count>5</count>
      </li>
      <li>
        <filter>
          <categories>
            <li>Leathers</li>
            <li>Textiles</li>
          </categories>
        </filter>
        <count>8</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>WoodLog</li>
      </thingDefs>
      <categories>
        <li>Leathers</li>
        <li>Textiles</li>
      </categories>
    </fixedIngredientFilter>
    <products>
      <EE_PrimitiveSplint>1</EE_PrimitiveSplint>
    </products>
    <recipeUsers>
      <li>CraftingSpot</li>
      <li>HandTailoringBench</li>
      <li>ElectricTailoringBench</li>
    </recipeUsers>
  </RecipeDef>

  <RecipeDef>
    <defName>Make_EE_PlasterBandage</defName>
    <label>制作石膏绷带</label>
    <description>利用石块磨粉、草药提取液和纺织品绷带制作坚固的医用固定石膏。</description>
    <jobString>制作石膏绷带中。</jobString>
    <workAmount>1000</workAmount>
    <ingredients>
      <li>
        <filter>
          <categories>
            <li>StoneChunks</li>
          </categories>
        </filter>
        <count>1</count>
      </li>
      <li>
        <filter>
          <categories>
            <li>Textiles</li>
          </categories>
        </filter>
        <count>15</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>MedicineHerbal</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <categories>
        <li>StoneChunks</li>
        <li>Textiles</li>
      </categories>
      <thingDefs>
        <li>MedicineHerbal</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <EE_PlasterBandage>2</EE_PlasterBandage>
    </products>
    <recipeUsers>
      <li>DrugLab</li>
      <li>CraftingSpot</li>
    </recipeUsers>
  </RecipeDef>

  <RecipeDef>
    <defName>Make_EE_Defibrillator</defName>
    <label>制作便携式除颤仪</label>
    <description>利用钢铁、工业元器件和高级元器件，精细装配一台便携式战地除颤仪。</description>
    <jobString>制作便携式除颤仪中。</jobString>
    <workAmount>2000</workAmount>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>30</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>3</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentSpacer</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Steel</li>
        <li>ComponentIndustrial</li>
        <li>ComponentSpacer</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <EE_Defibrillator>1</EE_Defibrillator>
    </products>
    <recipeUsers>
      <li>TableMachining</li>
      <li>FabricationBench</li>
    </recipeUsers>
    <skillRequirements>
      <Crafting>6</Crafting>
    </skillRequirements>
  </RecipeDef>

</Defs>
