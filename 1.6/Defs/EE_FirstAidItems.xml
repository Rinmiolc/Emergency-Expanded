<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- 急救包 (First Aid Kit) -->
  <ThingDef ParentName="ResourceBase">
    <defName>EE_FirstAidKit</defName>
    <label>First aid kit</label>
    <description>Contains crude herbal extract, simple pressure bandages, and splint boards. Designed for rapid field triage with zero outdoor bed penalties. Due to basic supplies, tend quality is relatively low. Cannot be used for routine surgeries. For massive bleeding, a kit can be used up to 5 times.</description>
    <graphicData>
      <texPath>Things/FirstAid/FirstAidKit</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>25</stackLimit>
    <statBases>
      <MaxHitPoints>60</MaxHitPoints>
      <MarketValue>12</MarketValue>
      <Mass>0.15</Mass>
      <Flammability>1.0</Flammability>
    </statBases>
    <thingCategories>
      <li>Medicine</li>
    </thingCategories>
  </ThingDef>

  <!-- 急救箱 (First Aid Box) -->
  <ThingDef ParentName="ResourceBase">
    <defName>EE_FirstAidBox</defName>
    <label>First aid box</label>
    <description>A standard military field medical kit containing rapid clotting powder, sterile pressure bandages, absorbable sutures, and potent analgesic needles. Very fast to use with no outdoor bed penalties. Ideal for treating massive hemorrhages on limbs and torso. Cannot be used for routine surgeries. Can be used up to 10 times for massive bleeding.</description>
    <graphicData>
      <texPath>Things/FirstAid/FirstAidBox</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>20</stackLimit>
    <statBases>
      <MaxHitPoints>85</MaxHitPoints>
      <MarketValue>28</MarketValue>
      <Mass>0.28</Mass>
      <Flammability>0.8</Flammability>
    </statBases>
    <thingCategories>
      <li>Medicine</li>
    </thingCategories>
  </ThingDef>

  <!-- 四肢止血带 (Tourniquet) -->
  <ThingDef ParentName="ResourceBase">
    <defName>EE_Tourniquet</defName>
    <label>Tourniquet</label>
    <description>A high-strength, portable tourniquet. Can only be applied to limbs. Extremely fast to apply, instantly binding and stopping all bleeding wounds on the target limb as a life-saving measure, bypassing long normal bandaging times.</description>
    <graphicData>
      <texPath>Things/Tourniquet</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>35</stackLimit>
    <statBases>
      <MaxHitPoints>50</MaxHitPoints>
      <MarketValue>9</MarketValue>
      <Mass>0.05</Mass>
      <Flammability>0.6</Flammability>
    </statBases>
    <thingCategories>
      <li>Medicine</li>
    </thingCategories>
  </ThingDef>

  <!-- 骨折环 (Primitive Splint) -->
  <ThingDef ParentName="ResourceBase">
    <defName>EE_FractureRing</defName>
    <label>Primitive splint</label>
    <description>A simple splint made of wooden sticks and rough bandages. Can be applied directly in the field to temporarily immobilize fractured bones, preventing secondary tissue damage from movement, but does not guarantee perfect bone alignment and carries a risk of malunion.</description>
    <graphicData>
      <texPath>Things/PrimitiveSplint</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>25</stackLimit>
    <statBases>
      <MaxHitPoints>50</MaxHitPoints>
      <MarketValue>8</MarketValue>
      <Mass>0.2</Mass>
      <Flammability>1.0</Flammability>
    </statBases>
    <thingCategories>
      <li>Medicine</li>
    </thingCategories>
  </ThingDef>

  <!-- 石膏绷带 (Plaster Bandage) -->
  <ThingDef ParentName="ResourceBase">
    <defName>EE_PlasterBandage</defName>
    <label>Plaster bandage</label>
    <description>Medical bandages infused with plaster powder. Hardens quickly when wet, providing rigid conservative immobilization. Must be applied on a clean hospital bed via plaster casting surgery. Completely prevents secondary damage and eliminates malunion risks.</description>
    <graphicData>
      <texPath>Things/PlasterBandage</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>15</stackLimit>
    <statBases>
      <MaxHitPoints>60</MaxHitPoints>
      <MarketValue>18</MarketValue>
      <Mass>0.4</Mass>
      <Flammability>0.2</Flammability>
    </statBases>
    <thingCategories>
      <li>Medicine</li>
    </thingCategories>
  </ThingDef>

  <!-- 除颤仪 (Defibrillator) -->
  <ThingDef ParentName="ResourceBase">
    <defName>EE_Defibrillator</defName>
    <label>Portable defibrillator</label>
    <description>A precise portable field defibrillator, designed to rescue pawns suffering from myocardial infarction or ventricular fibrillation (VF). Extremely effective in the early stage of VF (severity below 60%), but has a very low success rate for late-stage cardiac arrest unless another pawn is performing CPR to maintain perfusion. Consumed upon use. Fails cause minor electrical burn injuries.</description>
    <graphicData>
      <texPath>Things/Defibrillator</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>10</stackLimit>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <MarketValue>350</MarketValue>
      <Mass>1.5</Mass>
      <Flammability>0.4</Flammability>
    </statBases>
    <thingCategories>
      <li>Medicine</li>
    </thingCategories>
  </ThingDef>

  <!-- ================= 制作配方 ================= -->

  <RecipeDef>
    <defName>Make_EE_FractureRing</defName>
    <label>Make primitive splint</label>
    <description>Make a simple bone setting splint using wood and cloth.</description>
    <jobString>Making primitive splint.</jobString>
    <workAmount>600</workAmount>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>2</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Steel</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <EE_FractureRing>1</EE_FractureRing>
    </products>
    <recipeUsers>
      <li>CraftingSpot</li>
      <li>HandTailoringBench</li>
      <li>ElectricTailoringBench</li>
    </recipeUsers>
  </RecipeDef>

  <RecipeDef>
    <defName>Make_EE_PlasterBandage</defName>
    <label>Make plaster bandage</label>
    <description>Craft rigid plaster bandages from stone chunks, herbal extracts, and textiles.</description>
    <jobString>Making plaster bandage.</jobString>
    <workAmount>1000</workAmount>
    <ingredients>
      <li>
        <filter>
          <categories>
            <li>StoneChunks</li>
          </categories>
        </filter>
        <count>1</count>
      </li>
      <li>
        <filter>
          <categories>
            <li>Textiles</li>
          </categories>
        </filter>
        <count>15</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>MedicineHerbal</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <categories>
        <li>StoneChunks</li>
        <li>Textiles</li>
      </categories>
      <thingDefs>
        <li>MedicineHerbal</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <EE_PlasterBandage>2</EE_PlasterBandage>
    </products>
    <recipeUsers>
      <li>DrugLab</li>
      <li>CraftingSpot</li>
    </recipeUsers>
  </RecipeDef>

  <RecipeDef>
    <defName>Make_EE_Defibrillator</defName>
    <label>Make portable defibrillator</label>
    <description>Assemble a portable field defibrillator from steel, industrial components, and spacer components.</description>
    <jobString>Making portable defibrillator.</jobString>
    <workAmount>2000</workAmount>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>30</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>3</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentSpacer</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Steel</li>
        <li>ComponentIndustrial</li>
        <li>ComponentSpacer</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <EE_Defibrillator>1</EE_Defibrillator>
    </products>
    <recipeUsers>
      <li>TableMachining</li>
      <li>FabricationBench</li>
    </recipeUsers>
    <skillRequirements>
      <Crafting>6</Crafting>
    </skillRequirements>
  </RecipeDef>

</Defs>
